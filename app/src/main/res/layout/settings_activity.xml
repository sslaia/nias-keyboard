<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="?attr/colorSurface"
    android:padding="24dp"
    android:fitsSystemWindows="true">

    <!-- App Icon Placeholder -->
    <ImageView
        android:id="@+id/app_logo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="App Logo"
        android:src="@mipmap/ic_launcher_round" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nias Keyboard"
        android:textColor="?attr/colorPrimary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ya'ahowu!"
        android:textColor="?attr/colorPrimaryVariant"
        android:textSize="18sp"
        android:layout_marginBottom="32dp" />

    <!-- Language Selector Buttons -->
    <TextView
        android:id="@+id/tv_lang_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Language:"
        android:textColor="?attr/colorPrimaryVariant"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btn_lang_nia"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Li Niha"
            android:textColor="?attr/colorPrimary"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_lang_id"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Indonesia"
            android:textColor="?attr/colorPrimary"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_lang_en"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="English"
            android:textColor="?attr/colorPrimary"
            android:textAllCaps="false" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/check_dark_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable Dark Mode"
        android:textColor="?attr/colorPrimaryVariant"
        android:buttonTint="?attr/colorPrimary"
        android:textSize="18sp"
        android:layout_marginBottom="24dp" />

    <CheckBox
        android:id="@+id/check_wiki_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable Wikipedia Mode"
        android:textColor="?attr/colorPrimaryVariant"
        android:buttonTint="?attr/colorPrimary"
        android:textSize="18sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_enable_ime"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Activate Keyboard"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOnPrimary"
        android:textAllCaps="false"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tv_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Configure in Android Settings"
        android:textColor="?attr/colorOnSurface"
        android:textSize="14sp"
        android:alpha="0.7" />

</LinearLayout>